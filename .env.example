# HRM System Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
SERVER_PORT=8080

# Database Configuration
MYSQL_URL=jdbc:mysql://localhost:3306/hrm_db?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_secure_password_here

# JWT Configuration
# Generate a secure secret key (at least 32 characters)
JWT_SECRET=your-256-bit-secret-key-here-must-be-at-least-32-characters-long
JWT_EXPIRATION=86400000

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Application Configuration
PAYSLIP_PATH=payslips/
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=Your Company Address

# Logging Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
